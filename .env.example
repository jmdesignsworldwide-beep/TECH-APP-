# ─────────────────────────────────────────────────────────────
# JM Tech — Variables de entorno
# Copia este archivo a .env.local y rellena los valores.
# En Vercel: añade estas variables en Project Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────

# Supabase — PÚBLICAS (seguras para el cliente)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase — SECRETA (SOLO servidor). En Vercel márcala como "Sensitive".
# NUNCA uses el prefijo NEXT_PUBLIC_ con esta llave. NUNCA la pegues en chat/logs.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Secreto para firmar la sesión del modo DEMO (cuando no hay Supabase configurado).
# Genera uno aleatorio largo. Solo se usa en el fallback de demo del preview.
DEMO_SESSION_SECRET=change-me-to-a-long-random-string

# Dominio del email ficticio interno (el usuario NUNCA ve email; se mapea usuario→email).
# Mantenlo estable: el login traduce "usuario" a "usuario@<este-dominio>".
NEXT_PUBLIC_INTERNAL_EMAIL_DOMAIN=jmtech.local
